# Copy to .env.local and fill in. Never commit real values.

# OpenAI — powers the agent (gpt-4o).
OPENAI_API_KEY=sk-...

# Supabase — server-side only. The service_role key bypasses RLS, so it must
# never be exposed to the browser. Only used inside route handlers / scripts.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
