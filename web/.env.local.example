# Copy to .env.local and fill in. Never commit real values.

# OpenAI — powers the agent (gpt-4o).
OPENAI_API_KEY=sk-...

# Supabase — server-side only. The service_role key bypasses RLS, so it must
# never be exposed to the browser. Only used inside route handlers / scripts.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase Auth (browser) — these are PUBLIC and safe to expose. The anon key
# only grants what Row-Level Security allows.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (the "anon public" key)

# Telegram reminders (optional). Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC...
# The bot's username (without @), used to build the connect deep-link in the UI.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourTrailMateBot
# Shared secret protecting the cron endpoint; Vercel Cron sends it automatically.
CRON_SECRET=some-long-random-string
