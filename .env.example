# Copy this file to .env and fill in your keys.
# The .env file is gitignored — never commit real credentials.

# Required: OpenAI API key for the agent harness
OPENAI_API_KEY=your_openai_api_key_here

# Required for get_weather tool: OpenWeatherMap API key
# Free tier available at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
