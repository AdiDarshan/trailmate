{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trail",
  "type": "object",
  "required": ["name", "location"],
  "properties": {
    "name":            { "type": "string", "description": "Trail name in requested language" },
    "display_name":    { "type": "string", "description": "Name with region context, e.g. 'Carmel Trail, Haifa'" },
    "location": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "alt": { "type": ["number", "null"] }
      }
    },
    "trail_color":     { "type": "string", "enum": ["red", "blue", "green", "black", "orange", "white", "yellow"] },
    "network":         { "type": "string", "enum": ["local", "regional", "national"] },
    "ref":             { "type": "string", "description": "ITC trail reference number" },
    "description":     { "type": "string" },
    "distance_km":     { "type": "number", "minimum": 0 },
    "elevation_gain_m":{ "type": "number", "minimum": 0 },
    "difficulty":      { "type": "string", "enum": ["easy", "moderate", "hard"] }
  },
  "additionalProperties": false
}
